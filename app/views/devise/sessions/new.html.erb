<div class="container">
  <div class="screen">
    <div class="screen__content">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "login" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div class="form__field">
          <%= f.label :login, t("auth.email_or_phone") %>
          <%= f.text_field :login, autofocus: true, autocomplete: "login" %>
        </div>

        <div class="form__field">
          <%= f.label :password, t("auth.password") %>
          <%= f.password_field :password, autocomplete: "current-password" %>
          <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <div class="forgot__password">
              <%= link_to t("auth.forgot_password"), new_password_path(resource_name), class: "forgot-password" %>
            </div>
          <% end %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form__field form__field__checkbox">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, t("auth.remember_me") %>
          </div>
        <% end %>

        <div class="actions">
          <%= f.submit t("auth.login") %>
        </div>
      <% end %>

      <div class='social_login'>
        <p><%= t("auth.login_with") %></p>
        <div class="social_icons">
          <%- if devise_mapping.omniauthable? %>
            <%- resource_class.omniauth_providers.each do |provider| %>
              <%= button_to omniauth_authorize_path(resource_name, provider), data: { turbo: false } do %>
                <%= image_tag("social_icons/#{provider}.png", alt: t("auth.social_icon_alt", provider: provider.capitalize), class: "social_login_icon") %>
              <% end %>
            <% end %>
          <% end%>
        </div>
      </div>
    </div>
  </div>
</div>
