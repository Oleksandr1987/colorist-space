<div class="container">
  <div class="screen">
    <div class="screen__content">
      <h2 class="page_title"><%= t("auth.forgot_password_title") %></h2>
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div class="form__field">
         <%= f.label :email, t("auth.email") %>
         <%= f.email_field :email %>
        </div>
        <div class="actions">
          <%= f.submit t("auth.send_reset_link") %>
        </div>
        <div class="home-page__logo">
        <%= image_tag("logo_full_transpr.png", alt: "Colorist.Space", class: "logo-img") %>
      </div>
      <% end %>   
    </div>
  </div>
</div>