<% main_phone = client.phone %>

<ul class="phones-list">

  <!-- MAIN PHONE -->
  <li class="phone-item">
    <div class="phone-left">
      <a href="tel:<%= main_phone %>" class="phone-link full primary-phone">

        <svg xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-phone phone-icon">
          <path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/>
        </svg>

        <span class="phone-number">
          <%= main_phone %>
        </span>
        <!-- ACTIVE STAR -->
        <span class="phone-star active">
          <svg xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
            <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/>
          </svg>
        </span>

      </a>
    </div>

    <div class="phone-right">
        <button type="button"
                class="copy-btn"
                data-action="click->client-profile#copyPhone"
                data-phone="<%= main_phone %>">

          <%= image_tag "copy.png",
          class: "copy-icon" %>
        </button>
    </div>
  </li>

  <!-- ADDITIONAL PHONES -->
  <% client.client_phones.each do |phone| %>
    <% next if phone.phone == main_phone %>

    <li class="phone-item">
      <div class="phone-left">

        <a href="tel:<%= phone.phone %>" class="phone-link full">

          <svg xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-phone phone-icon">
            <path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/>
          </svg>

          <span class="phone-number">
            <%= phone.phone %>
          </span>

        </a>

        <%= button_to make_primary_client_path(client, phone: phone.phone),
              method: :patch,
              form: {
                data: { turbo_stream: true }
              },
              class: "phone-star-btn" do %>

            <svg xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-star">
              <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/>
            </svg>

        <% end %>
      </div>

      <div class="phone-right">
        <button type="button"
                class="copy-btn"
                data-action="click->client-profile#copyPhone"
                data-phone="<%= phone.phone %>">

          <%= image_tag "copy.png",
                class: "copy-icon" %>
        </button>
      </div>
    </li>
  <% end %>

</ul>
