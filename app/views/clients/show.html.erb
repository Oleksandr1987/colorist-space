<div data-controller="client-profile photo" class="client-profile-container">

  <!-- Header -->
  <div class="client-header">

    <div class="client-header-left">
      <h1><%= @client.full_name %></h1>
      <p class="client-phone"><%= @client.phone %></p>
    </div>

    <div class="client-header-right">
      <%= link_to calendar_appointments_path,
                  class: "button small new-appointment-button",
                  data: { turbo: false } do %>
        <%= t("clients.show.new_appointment") %>
      <% end %>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab-button active"
            data-client-profile-target="tab"
            data-tab-name="styles"
            data-action="click->client-profile#showTab">
      <%= t("clients.show.styles_tab") %>
    </button>

    <button class="tab-button"
            data-client-profile-target="tab"
            data-tab-name="info"
            data-action="click->client-profile#showTab">
      <%= t("clients.show.info_tab") %>
    </button>
  </div>

  <!-- STYLES TAB  -->
  <div id="styles-tab"
       data-client-profile-target="tabContent"
       class="tab-content active">

    <% @client.service_notes.order(created_at: :desc).each do |note| %>
      <div class="style-card">

        <!-- CLICKABLE THUMBNAIL → SHOW PAGE -->
        <%= link_to client_service_note_path(@client, note),
                    class: "style-photo-wrapper-link" do %>

          <div class="style-photo-wrapper">

            <% if note.photos.attached? %>

              <%= image_tag thumb(note.photos.first),
                    class: "style-photo" %>

              <% if note.photos.count > 1 %>
                <div class="style-photo-count">
                  +<%= note.photos.count - 1 %>
                </div>
              <% end %>

            <% else %>
              <div class="style-no-photo">No photo</div>
            <% end %>

            <div class="style-info-overlay">
              <div class="style-date"><%= l(note.created_at, format: "%B %d") %></div>
              <div class="style-service"><%= note.service_type.capitalize %></div>
            </div>

          </div>

        <% end %>

      </div>
    <% end %>

    <!-- ADD STYLE BUTTON -->
    <div class="add-style-wrapper" style="margin-top: 1.5rem; text-align:center;">
      <%= link_to new_client_service_note_path(@client),
                  class: "button small new-appointment-button add-style-button" do %>
        + <%= t("clients.show.add_style") %>
      <% end %>
    </div>
  </div>


  <!-- INFO TAB  -->
  <div id="info-tab"
       data-client-profile-target="tabContent"
       class="tab-content">

    <div class="client-info">

      <p><strong><%= t("clients.show.details.phone") %>:</strong>
        <%= @client.phone %></p>

      <p><strong><%= t("clients.show.details.hair_type") %>:</strong>
        <%= t("clients.hair.types.#{@client.hair_type.downcase}") if @client.hair_type %></p>

      <p><strong><%= t("clients.show.details.hair_length") %>:</strong>
        <%= t("clients.hair.lengths.#{@client.hair_length.downcase}") if @client.hair_length %></p>

      <p><strong><%= t("clients.show.details.hair_structure") %>:</strong>
        <%= t("clients.hair.structures.#{@client.hair_structure.downcase}") if @client.hair_structure %></p>

      <p><strong><%= t("clients.show.details.hair_density") %>:</strong>
        <%= t("clients.hair.density.#{@client.hair_density.downcase}") if @client.hair_density %></p>

      <p><strong><%= t("clients.show.details.scalp_condition") %>:</strong>
        <%= t("clients.hair.scalp.#{@client.scalp_condition.downcase}") if @client.scalp_condition %></p>

      <p><strong><%= t("clients.show.details.note") %>:</strong>
        <%= @client.note %></p>

      <div class="actions">
        <%= link_to t("clients.show.edit_client"),
                    edit_client_path(@client),
                    class: "button secondary" %>

        <%= button_to t("clients.show.delete_client"),
                      client_path(@client),
                      method: :delete,
                      data: { turbo_confirm: t("clients.show.delete_client_confirm") },
                      class: "button delete" %>
      </div>

    </div>
  </div>

  <!-- FULLSCREEN -->
  <div data-photo-target="modal" class="fullscreen hidden">
    <div class="fullscreen-backdrop" data-action="click->photo#close"></div>
    <button class="fullscreen-close" data-action="click->photo#close">×</button>
    <img data-photo-target="modalImage" class="fullscreen-image">
  </div>

</div>
