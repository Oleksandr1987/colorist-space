<div class="clients-page">
  <div data-controller="client-search" class="clients-container">

    <input type="text"
           data-client-search-target="input"
           placeholder="<%= t("clients.search_placeholder") %>"
           class="search-input compact">

    <div class="client-list indexed">
      <% if @clients.present? %>
        <% @clients.group_by { |c| c.first_name[0].upcase }.sort.each do |letter, list| %>
          <div class="client-group" data-client-search-target="group">
            <div class="letter-index"><%= letter %></div>

            <div class="letter-names">
              <% list.each do |client| %>

                <div class="client-item"
                     data-client-search-target="item"
                     data-phone="<%= [
                       client.phone,
                       client.client_phones.map(&:phone)
                     ].flatten.compact.join(' ') %>">

                  <%= link_to "#{client.first_name} #{client.last_name}",
                              client_path(client),
                              class: "client-link" %>

                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p><%= t("clients.none_found") %></p>
      <% end %>
    </div>

    <%= link_to new_client_path, class: "floating-add-button" do %>
        <%= image_tag "plus.png",
        width: 46,
        height: 46 %>
    <% end %>

  </div>
</div>
