<div class="wizard-modal hidden"
     data-type="service">
  <div class="wizard-modal-content">
    <!-- Header -->
    <div class="appointment-header modal-header">
      <div class="appointment-header-left">
        <button type="button"
                class="back-link inline"
                data-action="click->appointment#close">
          <%= image_tag "delete.png",
                class: "wiz-icon",
                width: 24,
                height: 24 %>
        </button>
        <h2>
          <%= t("appointments.modals.service.title") %>
        </h2>
      </div>
      <button type="button"
              class="wizard-save-button"
              data-action="click->appointment#close">
        <%= t("common.save").upcase %>
      </button>
    </div>
    <!-- Search -->
    <div class="wizard-modal-search">
      <input
        type="text"
        class="form-input"
        placeholder="<%= t('appointments.modals.service.search') %>"
        data-action="input->appointment#search">
    </div>
    <!-- Services -->
    <div class="wizard-modal-list"
         data-appointment-target="list">
      <% current_user.services
                     .where(service_type: "service")
                     .order(:subtype)
                     .each do |service| %>
        <label class="wizard-check-row">
          <%= check_box_tag(
                "appointment[modal_dummy][]",
                service.id,
                false,
                data: {
                  subtype: service.subtype,
                  price: service.price,
                  type: "service",
                  action: "change->appointment#toggleService"
                }
              ) %>
          <span class="wizard-check-title">
            <%= service.subtype %>
          </span>
          <span class="wizard-check-price">
            <%= number_to_currency(
                  service.price,
                  unit: "",
                  precision: 0
                ) %> ₴
          </span>
        </label>
      <% end %>
    </div>
  </div>
</div>
