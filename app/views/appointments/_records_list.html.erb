<div class="expenses-scroll-wrapper">
  <% @appointments_by_month.each do |month_name, appointments| %>
    <div class="monthly-expense-group"
         data-controller="collapse">
      <div class="month-header-aligned"
           data-action="click->collapse#toggle">
        <span class="month-header-title">
          <%= month_name %>
        </span>
        <div class="month-header-right">
          <span class="month-header-amount">
            <%= t("appointments.history.records",
                  count: appointments.count) %>
          </span>
        </div>
      </div>

      <ul class="expenses-list collapsible hidden"
          data-collapse-target="content">

        <% appointments
             .sort_by { |a| [a.appointment_date, a.appointment_time] }
             .each do |appointment| %>

          <li class="appointment-record">
            <div class="appointment-record-header">
              <%= link_to edit_appointment_path(appointment),
                          class: "appointment-record-content" do %>
                <div class="appointment-record-date">
                  <strong>
                    <%= l(
                          appointment.appointment_date,
                          format: :default
                        ) %>
                    /
                    <%= appointment.appointment_time.strftime("%H:%M") %>

                    <% if appointment.end_time.present? %>
                      –
                      <%= appointment.end_time.strftime("%H:%M") %>
                    <% end %>
                  </strong>
                </div>

                <div class="appointment-record-client">
                  <%= appointment.client.full_name %>
                </div>

                <% if appointment.service_name.present? %>
                  <% appointment.service_name.split(" + ").each do |service| %>
                    <div class="appointment-record-service">
                      <%= service %>
                    </div>
                  <% end %>
                <% end %>
              <% end %>

              <div class="appointment-record-actions">
                <%= link_to client_path(appointment.client),
                            class: "appointment-action-button",
                            data: { turbo: false } do %>
                  <%= image_tag "client.png",
                        class: "wiz-icon",
                        width: 16,
                        height: 16 %>
                <% end %>

                <%= link_to(
                      appointment.service_note.present? ?
                        client_service_note_path(
                          appointment.client,
                          appointment.service_note
                        ) :
                        new_client_service_note_path(
                          appointment.client,
                          appointment_id: appointment.id
                        ),
                      class: "appointment-action-button",
                      data: { turbo: false }
                    ) do %>
                  <%= image_tag "notes.png",
                        class: "wiz-icon",
                        width: 16,
                        height: 16 %>
                <% end %>

                <%= button_to appointment_path(appointment),
                      method: :delete,
                      form: {
                        data: {
                          turbo_confirm:
                            t("appointments.confirm.delete")
                        }
                      },
                      class: "appointment-action-button appointment-delete-button" do %>
                  <%= image_tag "delete.png",
                        class: "wiz-icon",
                        width: 16,
                        height: 16 %>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
