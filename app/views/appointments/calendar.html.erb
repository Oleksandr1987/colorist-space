<div
  data-controller="calendar-view"
  data-calendar-view-client-id-value="<%= params[:client_id] || @client&.id %>"
  data-calendar-view-dates-with-appointments-value="<%= @dates_with_appointments.to_json%>"
  data-calendar-view-client-icon-value="<%= asset_path('client.png') %>"
  data-calendar-view-notes-icon-value="<%= asset_path('notes.png') %>"
  data-calendar-view-delete-icon-value="<%= asset_path('delete.png') %>"
  data-calendar-view-translations-value='{
    "days": {
      "sun": "<%= t('appointments.calendar_view.days.sun') %>",
      "mon": "<%= t('appointments.calendar_view.days.mon') %>",
      "tue": "<%= t('appointments.calendar_view.days.tue') %>",
      "wed": "<%= t('appointments.calendar_view.days.wed') %>",
      "thu": "<%= t('appointments.calendar_view.days.thu') %>",
      "fri": "<%= t('appointments.calendar_view.days.fri') %>",
      "sat": "<%= t('appointments.calendar_view.days.sat') %>"
    },
    "available": "<%= t('appointments.calendar_view.available') %>",
    "edit": "<%= t('appointments.index.edit') %>",
    "delete": "<%= t('appointments.index.delete') %>",
    "delete_confirm": "<%= t('appointments.confirm.delete') %>",
    "locale": "<%= I18n.locale %>"
  }'
  class="calendar-wrapper"
>

  <div class="calendar-header">
    <button class="nav-btn" data-action="click->calendar-view#prevMonth">
      <%= image_tag "back.png", class: "wizard-nav-icon" %>
    </button>
    <h2 data-calendar-view-target="monthLabel"></h2>
    <button class="nav-btn" data-action="click->calendar-view#nextMonth">
      <%= image_tag "next.png", class: "wizard-nav-icon" %>
    </button>
  </div>

  <div class="calendar-grid" data-calendar-view-target="calendarDays"></div>

  <div class="calendar-today-label" data-calendar-view-target="selectedDateLabel"></div>

  <div class="calendar-actions">
    <%= link_to t("appointments.calendar_view.add"),
          new_appointment_path(date: params[:date]),
          class: "button purple",
          data: { action: "calendar-view#openNewAppointment" } %>

    <%= link_to all_appointments_path, class: "calendar-all-button" do %>
      <%= image_tag "notes.png",
            class: "wiz-icon",
            width: 22,
            height: 22 %>
    <% end %>
  </div>

  <div class="timeline-wrapper">
    <h4><%= t("appointments.calendar_view.header") %></h4>
    <div data-calendar-view-target="timeline" class="timeline"></div>
  </div>
</div>
