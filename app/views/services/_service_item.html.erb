<div class="service-item"
    data-controller="popover"
    data-name="<%= [service.subtype, service.unit, service.price].compact.join(' ').downcase %>">

  <div class="service-info">
    <strong><%= service.subtype %></strong>
    — <%= number_to_currency(service.price, unit: "", precision: 0) %> ₴
    <% if service.unit.present? %>
      (<%= service.unit %>)
    <% end %>
  </div>

  <div class="service-actions">
    <button class="popover-toggle" data-popover-target="button" data-action="click->popover#toggle">
      <%= image_tag "pencil.png",
            class: "wiz-icon",
            width: 24,
            height: 24 %>
    </button>

    <div class="popover-menu hidden" data-popover-target="menu">
      <%= link_to t("services.list.edit"), edit_service_path(service), class: "popover-item" %>

      <%= button_to service_path(service),
            method: :delete,
            data: { turbo_confirm: t("services.list.confirm_delete") },
            class: "popover-item delete-button" do %>
        <%= t("services.list.delete") %>
      <% end %>
    </div>
  </div>
</div>
