<div class="container">
  <div class="screen">
    <div class="screen__content">
      <div class="language_switcher top_right">
        <select class="language_select" onchange="window.location = '?locale=' + this.value;">
          <option value="uk" <%= 'selected' if I18n.locale == :uk %>>Українська</option>
          <option value="en" <%= 'selected' if I18n.locale == :en %>>English</option>
        </select>
      </div>

      <h2 class="page_title"><%= t("auth.login_title") %></h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "login" }) do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>

        <!-- Email or Phone -->
        <div class="form__field">
          <%= f.label :login, t("auth.email_or_phone") %>
          <%= f.text_field :login, autofocus: true, autocomplete: "login" %>
        </div>

        <!-- Password -->
        <div class="form__field">
          <%= f.label :password, t("auth.password") %>
          <%= f.password_field :password, autocomplete: "current-password" %>
          <div class="forgot__password">
            <%= link_to t("auth.forgot_password"), new_password_path(resource_name), class: "forgot-password" %>
          </div>
        </div>

        <!-- Remember me -->
        <% if devise_mapping.rememberable? %>
          <div class="form__field form__field__checkbox">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, t("auth.remember_me") %>
          </div>
        <% end %>

        <!-- Login button -->
        <div class="actions">
          <%= f.submit t("auth.login") %>
        </div>

      <% end %>
      <!-- ====================== END FORM ====================== -->

      <!-- Social login -->
      <div class="social_login">
        <p><%= t("auth.login_with") %></p>
        <div class="social_icons">

          <%= button_to omniauth_authorize_path(:user, :facebook), data: { turbo: false } do %>
            <%= image_tag("social_icons/facebook.png", class: "social_login_icon") %>
          <% end %>

          <%= button_to omniauth_authorize_path(:user, :google_oauth2), data: { turbo: false } do %>
            <%= image_tag("social_icons/google_oauth2.png", class: "social_login_icon") %>
          <% end %>

          <%= button_to omniauth_authorize_path(:user, :instagram), data: { turbo: false } do %>
            <%= image_tag("social_icons/instagram.png", class: "social_login_icon") %>
          <% end %>

        </div>
      </div>

      <!-- Register -->
      <div class="login_register">
        <p class="home_register_label"><%= t("auth.need_register") %></p>
        <%= link_to t("auth.signup"), new_user_registration_path, class: "home_register_link" %>
      </div>

      <!-- Logo -->
      <div class="home_logo">
        <%= image_tag("logo_full_transpr.png", alt: "Colorist.Space", class: "logo-img") %>
      </div>
    </div>
  </div>
</div>
