<div class="wizard-screen"
     data-controller="wizard"
     data-wizard-initial-step-value="<%= params[:step] %>"
     data-wizard-unsaved-title-value="<%= t('common.unsaved_changes_title') %>"
     data-wizard-unsaved-message-value="<%= t('common.unsaved_changes_message') %>"
     data-wizard-save-label-value="<%= t('common.save') %>"
     data-wizard-discard-label-value="<%= t('common.discard') %>"
     data-wizard-cancel-label-value="<%= t('common.cancel') %>">
  <%= form_with(model: [@client, @service_note], html: { multipart: true }) do |f| %>

    <% if @service_note.errors.any? %>
      <div class="form-errors">
        <% @service_note.errors.full_messages.each do |message| %>
          <div class="form-error">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= hidden_field_tag :appointment_id, params[:appointment_id] %>
    <!-- TOP BAR -->
    <div class="wizard-top">
      <button type="button" data-action="click->wizard#close">
        <%= image_tag "delete.png",
              class: "wiz-icon-close" %>
      </button>
      <span data-wizard-target="title">Services</span>
      <button type="submit">SAVE</button>
      <div id="save_status"></div>
    </div>

    <!-- NAV -->
    <div class="wizard-nav">
      <div class="wizard-progress">
        <div class="wizard-progress-bar" data-wizard-target="progress"></div>
      </div>

      <!-- SERVICES -->
      <div data-action="click->wizard#go" data-step="0" class="wiz-item">
        <%= image_tag "services.png",
              class: "wiz-icon",
              width: 34,
              height: 34 %>
      </div>

      <!-- HAIRCUT -->
      <div data-action="click->wizard#go" data-step="1" class="wiz-item">
        <%= image_tag "brush.png",
              class: "wiz-icon",
              width: 34,
              height: 34 %>
      </div>

      <!-- FORMULA -->
      <div data-action="click->wizard#go" data-step="2" class="wiz-item active">
        <%= image_tag "formula.png",
              class: "wiz-icon",
              width: 34,
              height: 34 %>
      </div>

      <!-- CARE PRODUCTS -->
      <div data-action="click->wizard#go"data-step="3"class="wiz-item">
        <%= image_tag "skincare.png",
            class: "wiz-icon",
            width: 34,
            height: 34 %>
      </div>

      <!-- PHOTOS -->
      <div data-action="click->wizard#go" data-step="4" class="wiz-item">
         <%= image_tag "camera.png",
              class: "wiz-icon",
              width: 34,
              height: 34 %>
      </div>

      <!-- NOTES -->
      <div data-action="click->wizard#go" data-step="5" class="wiz-item">
        <%= image_tag "notes.png",
              class: "wiz-icon",
              width: 34,
              height: 34 %>
      </div>

    </div>

    <!-- CONTENT -->
    <div class="wizard-content" data-wizard-target="container">

      <div class="wizard-step" data-wizard-target="step">
        <%= render "service_notes/steps/services", f: f %>
      </div>

      <div class="wizard-step" data-wizard-target="step">
        <%= render "service_notes/steps/haircut", f: f %>
      </div>

      <div class="wizard-step active" data-wizard-target="step">
        <%= render "service_notes/steps/formula", f: f %>
      </div>

      <div class="wizard-step" data-wizard-target="step">
        <%= render "service_notes/steps/care_products", f: f %>
      </div>

      <div class="wizard-step" data-wizard-target="step">
        <%= render "service_notes/steps/photos", f: f %>
      </div>

      <div class="wizard-step" data-wizard-target="step">
        <%= render "service_notes/steps/notes", f: f %>
      </div>

    </div>

    <!-- BOTTOM -->
    <div class="wizard-bottom">
      <button type="button"
        data-action="click->wizard#prev"
        data-wizard-target="prevButton">

        <%= image_tag "back.png",
            width: 24,
            height: 24,
            class: "wizard-nav-icon" %>

        BACK
      </button>

      <button type="button"
        data-action="click->wizard#next"
        data-wizard-target="nextButton">

        <span data-wizard-target="nextLabel">
          NEXT
        </span>

        <%= image_tag "next.png",
            width: 24,
            height: 24,
            class: "wizard-nav-icon",
            data: { wizard_target: "nextIcon" } %>

        <%= image_tag "save.png",
            width: 24,
            height: 24,
            class: "wizard-nav-icon",
            style: "display:none",
            data: { wizard_target: "saveIcon" } %>
      </button>
    </div>

  <% end %>
  <div class="unsaved-modal hidden" data-wizard-target="unsavedModal">
    <div class="unsaved-modal-backdrop"></div>

    <div class="unsaved-modal-card">
      <h3 data-wizard-target="unsavedTitle"></h3>
      <p data-wizard-target="unsavedMessage"></p>

      <div class="unsaved-modal-actions">
        <button type="button"
                class="button secondary"
                data-action="click->wizard#cancelClose">
          <%= t("common.cancel") %>
        </button>

        <button type="button"
                class="button danger"
                data-action="click->wizard#discardChanges">
          <%= t("common.discard") %>
        </button>

        <button type="button"
                class="button primary"
                data-action="click->wizard#saveAndClose">
          <%= t("common.save") %>
        </button>
      </div>
    </div>
  </div>
</div>
