<template data-formula-target="template">
  <div class="formula-step-wrapper"
      data-controller="collapse"
      data-step-id="NEW_RECORD">

  <!-- HEADER -->
    <div class="formula-step-header"
        data-action="click->collapse#toggle">

      <span>
        <%= t("haircut.step") %>
        <span class="step-number"></span>
      </span>

      <svg class="chevron"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>

  <!-- CONTENT -->
    <div class="formula-step-content"
        data-collapse-target="content">
      <div class="formula-card"
          data-controller="developer"
          data-step-id="NEW_RECORD">

        <!-- SECTION -->
        <input type="hidden"
              name="service_note[formula_steps_attributes][NEW_RECORD][section]"
              value="__SECTION__" />

        <input type="hidden"
          name="service_note[formula_steps_attributes][NEW_RECORD][id]" />

        <!-- HEADER -->
        <div class="formula-header">
          <span>__SECTION__</span>

          <div class="step-remove">
            <input type="hidden"
                  name="service_note[formula_steps_attributes][NEW_RECORD][_destroy]"
                  value="0"
                  class="destroy-field" />

            <button type="button"
                    data-action="click->formula#removeStep">
              <%= image_tag "delete.png",
                      class: "clear-icon" %>
            </button>
          </div>
        </div>

        <!-- COLORS -->
        <div class="formula-block">
          <div class="block-title">
            <span> <%= image_tag "paint.png", class: "wiz-icon",
                                width: 24,
                                height: 24 %>COLORS</span>

            <button type="button"
                    class="add-btn-small add-color-btn"
                    data-action="click->formula#openColorModal">
               <%= image_tag "plus.png", class: "add-icon" %>
            </button>
          </div>

          <!-- DISPLAY LIST -->
          <div class="colors-display"
              data-color-target="list">
          </div>

          <!-- ✅ HIDDEN (Rails nested) -->
          <div class="hidden"
              data-formula-target="colorsList">
          </div>

          <!-- TEMPLATE для нових інгредієнтів -->
          <template data-formula-target="ingredientTemplate">
            <div class="ingredient-fields" data-id="NEW_ID">

              <input type="hidden"
                name="service_note[formula_steps_attributes][STEP_ID][formula_ingredients_attributes][NEW_ID][shade]"
                data-field="shade">

              <input type="hidden"
                name="service_note[formula_steps_attributes][STEP_ID][formula_ingredients_attributes][NEW_ID][brand]"
                data-field="brand">

              <input type="hidden"
                name="service_note[formula_steps_attributes][STEP_ID][formula_ingredients_attributes][NEW_ID][amount]"
                data-field="amount">

              <input type="hidden"
                name="service_note[formula_steps_attributes][STEP_ID][formula_ingredients_attributes][NEW_ID][formula_product_id]"
                data-field="formula_product_id">

              <input type="hidden"
                name="service_note[formula_steps_attributes][STEP_ID][formula_ingredients_attributes][NEW_ID][price]"
                data-field="price">

              <input type="hidden"
                name="service_note[formula_steps_attributes][STEP_ID][formula_ingredients_attributes][NEW_ID][_destroy]"
                value="0"
                data-field="destroy">
            </div>
          </template>

        </div>

        <!-- DEVELOPER -->
        <div class="formula-block">
          <div class="block-title">
            <span> <%= image_tag "percent.png", class: "wiz-icon",
                                width: 24,
                                height: 24 %>DEVELOPER</span>
            <button type="button"
              class="add-btn-small add-dev-btn"
              data-action="click->developer#openModal">
               <%= image_tag "plus.png", class: "add-icon" %>
            </button>
          </div>

          <input type="hidden"
          name="service_note[formula_steps_attributes][NEW_RECORD][oxidant]"
          data-developer-target="input" />

          <div class="dev-list"
              data-developer-target="list">
          </div>

          <template data-developer-target="itemTemplate">

            <div class="dev-row-display">

              <div class="dev-left">

                <span class="dev-name"></span>

                <span class="dev-separator">|</span>

                <span class="dev-ratio"></span>

              </div>

              <div class="dev-right">

                <span class="dev-amount"></span>

                <div class="dev-actions"
                    data-controller="popover">

                  <button
                    type="button"
                    class="edit-btn"
                    data-action="click->popover#toggle">

                    <%= image_tag "pencil.png",
                          class: "wiz-icon",
                          width: 18,
                          height: 18 %>

                  </button>

                  <div class="popover-menu hidden"
                      data-popover-target="menu">

                    <button
                      type="button"
                      class="edit-item">

                      Edit

                    </button>

                    <button
                      type="button"
                      class="delete-item">

                      Delete

                    </button>

                  </div>

                </div>

              </div>

            </div>

          </template>
        </div>

        <!-- TIME -->
        <div class="formula-block">
          <div class="block-title">
            <span> <%= image_tag "time.png", class: "wiz-icon",
                                width: 24,
                                height: 24 %>TIME</span>
          </div>

          <input type="text"
                inputmode="numeric"
                pattern="[0-9]*"
                name="service_note[formula_steps_attributes][NEW_RECORD][time]"
                class="input-line"
                value="0" />
        </div>

        <!-- DEVELOPER MODAL -->
        <%= render "service_notes/developer_modal" %>

      </div>
    </div>
  </div>
</template>
