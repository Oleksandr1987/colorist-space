<div class="haircut-container"
     data-controller="haircut"
     data-haircut-title-value="<%= t('haircut.title') %>"
     data-haircut-select-zone-value="<%= t('haircut.select_zone') %>"
     data-haircut-zones-value="<%= {
       "lower occipital" => t("haircut.zones.lower_occipital"),
				"upper occipital" => t("haircut.zones.upper_occipital"),
				"temporal" => t("haircut.zones.temporal"),
				"fringe" => t("haircut.zones.fringe"),
				"crown" => t("haircut.zones.crown"),
				"all over" => t("haircut.zones.all_over")
     }.to_json %>">

  <div class="haircut-steps"
       data-haircut-target="container">
    <%= f.fields_for :haircut_steps do |step_form| %>
      <div class="formula-step-wrapper"
           data-controller="collapse">
        <!-- HEADER -->
        <div class="formula-step-header"
             data-action="click->collapse#toggle">
          <span>
            STEP <span class="step-number"></span>
          </span>

          <svg class="chevron"
               xmlns="http://www.w3.org/2000/svg"
               viewBox="0 0 24 24"
               fill="none"
               stroke="currentColor"
               stroke-width="2">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </div>

        <!-- CONTENT -->
        <div class="formula-step-content"
             data-collapse-target="content">
          <div class="formula-card">
            <!-- HEADER -->
            <div class="formula-header">
              <span class="haircut-zone-title">
                <%= step_form.object.zone.present? ?
										t("haircut.zones.#{step_form.object.zone.parameterize(separator: '_')}") :
										t("haircut.zone") %>
              </span>
              <div class="step-remove">
                <%= step_form.hidden_field :_destroy,
                      value: 0,
                      class: "destroy-field" %>
                <%= step_form.hidden_field :zone %>
                <button type="button"
                        data-action="click->haircut#removeStep">
                  <%= image_tag "delete.png",
                      class: "clear-icon" %>
                </button>
              </div>
            </div>
            <!-- INSTRUMENT -->
            <%= render(
              "service_notes/haircut_picker_field",
              form: step_form,
              field: :instrument,
              value: step_form.object.instrument,
              collection: HaircutStep::INSTRUMENTS,
              title: t("haircut.instrument"),
              translation_scope: "haircut.instruments",
              placeholder: t("haircut.select_instrument")
            ) %>
            <!-- PARTING -->
            <%= render(
              "service_notes/haircut_picker_field",
              form: step_form,
              field: :parting,
              value: step_form.object.parting,
              collection: HaircutStep::PARTINGS,
              title: t("haircut.parting"),
              translation_scope: "haircut.partings",
              placeholder: t("haircut.select_parting")
            ) %>
            <!-- ELEVATION -->
            <%= render(
              "service_notes/haircut_picker_field",
              form: step_form,
              field: :elevation,
              value: step_form.object.elevation,
              collection: HaircutStep::ELEVATIONS,
              title: t("haircut.elevation"),
              translation_scope: "haircut.elevations",
              placeholder: t("haircut.select_elevation")
            ) %>
            <!-- CUT -->
            <%= render(
              "service_notes/haircut_picker_field",
              form: step_form,
              field: :cut_type,
              value: step_form.object.cut_type,
              collection: HaircutStep::CUT_TYPES,
              title: t("haircut.cut_type"),
              translation_scope: "haircut.cut_types",
              placeholder: t("haircut.select_cut_type")
            ) %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- ADD STEP -->
  <div class="formula-add-step <%= 'hidden' if @service_note.haircut_steps.empty? %>"
       data-haircut-target="addStep"
       data-controller="collapse">
    <div class="add-step-btn"
         data-action="click->collapse#toggle">
      <span><%= t("haircut.step") %></span>

      <svg class="chevron"
           xmlns="http://www.w3.org/2000/svg"
           viewBox="0 0 24 24"
           fill="none"
           stroke="currentColor"
           stroke-width="2">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>

    <div class="add-step-content hidden"
         data-collapse-target="content">
      <div class="haircut-zones-grid">
        <% HaircutStep::ZONES.each do |zone| %>
          <button type="button"
                  class="section-btn"
                  data-action="click->haircut#createStep click->collapse#close"
                  data-zone="<%= zone %>">
            <%= t("haircut.zones.#{zone.parameterize(separator: '_')}") %>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%= render "service_notes/empty_haircut_step" if @service_note.haircut_steps.empty? %>
  <%= render "service_notes/haircut_step_template" %>
  <%= render "service_notes/picker_modal" %>
</div>
