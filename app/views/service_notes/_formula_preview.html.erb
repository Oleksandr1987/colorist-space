<div class="formula-preview-card">

  <div class="formula-preview-title">
    <%= step.section&.humanize || "Step" %>
  </div>

  <% if step.formula_ingredients.any? %>
    <div class="formula-preview-group">

      <div class="formula-icon">
        <%= image_tag "paint.png", class: "wiz-icon",
                            width: 24,
                            height: 24 %>
      </div>

      <div class="formula-content">

        <% step.formula_ingredients.each do |ingredient| %>

          <div class="formula-row">
            <span>
              <%= ingredient.shade %>
              <%= ingredient.brand %>
            </span>

            <span>
              <%= ingredient.amount %>g
            </span>
          </div>

        <% end %>

      </div>

    </div>
  <% end %>

  <% if step.oxidant.present? %>

    <% data = step.oxidant || {} %>
    <% product = step.oxidant_product %>

    <div class="formula-preview-group">

      <div class="formula-icon">
        <%= image_tag "percent.png", class: "wiz-icon",
                            width: 24,
                            height: 24 %>
      </div>

      <div class="formula-content">

        <div class="formula-row">
          <span>
            <%= [product&.brand, product&.name].compact.join(" ").presence || "Unknown" %>
            <%= data["ratio"] %>
          </span>

          <span>
            <%= data["amount"] %><%= product&.unit || "g" %>
          </span>
        </div>

      </div>

    </div>

  <% end %>

  <% if step.time.present? %>

    <div class="formula-preview-group">

      <div class="formula-icon">
        <%= image_tag "time.png", class: "wiz-icon",
                            width: 24,
                            height: 24 %>
      </div>

      <div class="formula-content">

        <div class="formula-row">
          <span><%= step.time %> min</span>
        </div>

      </div>

    </div>

  <% end %>

</div>
