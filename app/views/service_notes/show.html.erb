<div data-controller="photo"
     data-photo-mode-value="inline"
     data-photo-photos-value="<%= @service_note.photos.map { |p| url_for(p) }.to_json %>"
     data-photo-index-value="0"
     class="note-viewer">

  <!-- PHOTO -->
  <div class="note-photo-wrapper"
       data-photo-target="photoContainer"
       data-action="
          touchstart->photo#touchStart
          touchend->photo#touchEnd
          click->photo#clickNext
       ">

    <button class="photo-back-btn" onclick="history.back()">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
        viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="m12 8-4 4 4 4"/>
        <path d="M16 12H8"/>
      </svg>
    </button>

    <% if @service_note.photos.attached? %>
      <%= image_tag optimized(@service_note.photos.first),
            class: "note-photo",
            data: { photo_target: "photo" } %>
    <% else %>
      <div class="note-no-photo">No Photo</div>
    <% end %>
  </div>

  <!-- DOTS -->
  <div class="note-dots">
    <% @service_note.photos.count.times do |i| %>
      <div class="dot <%= "active" if i == 0 %>" data-photo-target="dot"></div>
    <% end %>
  </div>

  <!-- HEADER -->
  <div class="note-header-modern">
    <div>
      <div class="note-date">
        <%= l(@service_note.appointment.appointment_date, format: "%B %d") %>
      </div>

      <div class="note-client">
        <%= @client.full_name %>
      </div>
    </div>

    <div class="note-actions-modern">
      <%= link_to edit_client_service_note_path(@client, @service_note) do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="lucide lucide-pencil" width="20" height="20"
          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2a2.828 2.828 0 1 1 4 4L7 21l-4 1 1-4Z" />
          <path d="M16 5l3 3" />
        </svg>
      <% end %>

      <%= button_to client_service_note_path(@client, @service_note),
            method: :delete,
            data: { turbo_confirm: "Delete?" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" 
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ellipsis-vertical-icon lucide-ellipsis-vertical">
        <circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
      <% end %>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="note-content">

    <!-- FORMULA -->
    <div class="note-section">
      <div class="note-section-title"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="wiz-icon"><path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/></svg>
        <span>FORMULA</span>
      </div>

      <div data-controller="collapse" class="note-step">

        <!-- HEADER (кнопка) -->
        <div class="note-step-pill"
            data-action="click->collapse#toggle">

          <span>STEP 1</span>

          <!-- стрілка -->
          <svg class="chevron"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </div>

        <!-- CONTENT -->
        <div class="note-step-content hidden"
            data-collapse-target="content">

          <%= render "service_notes/formula_preview",
                service_note: @service_note %>

        </div>

      </div>
    </div>

    <!-- SERVICES -->
    <div class="note-section">
      <div class="note-section-title"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="wiz-icon"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></svg>
        <span>SERVICES</span>
      </div>

      <% if @service_note.services.any? %>
        <% @service_note.services.each do |service| %>
          <div class="note-row"><%= service.name %></div>
        <% end %>
      <% else %>
        <div class="note-row empty">No services</div>
      <% end %>
    </div>

    <!-- NOTES -->
    <div class="note-section">
      <div class="note-section-title"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="wiz-icon"><path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/><path d="M2 6h4"/><path d="M2 10h4"/><path d="M2 14h4"/><path d="M2 18h4"/><path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/></svg>
        <span>NOTES</span>
      </div>

      <div class="note-label">Final price</div>
      <div class="note-value">
        <%= @service_note.final_price || 0 %>
      </div>

      <% if @service_note.notes.present? %>
        <div class="note-label">Notes</div>
        <div class="note-value">
          <%= @service_note.notes %>
        </div>
      <% end %>
    </div>

  </div>
</div>
